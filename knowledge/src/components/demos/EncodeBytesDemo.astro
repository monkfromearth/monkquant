---
/**
 * Three chunks, three little codebooks. Drag any chunk's point and its byte code flips
 * independently. The vector becomes one short row of codes. (Lesson 3.2.)
 */
const W = 360, H = 200;
---

<div class="mt-demo mt-encode-demo my-6 bg-white border border-mt-border rounded-2xl p-6" data-w={W}>
    <p class="text-xs uppercase tracking-wide text-mt-muted font-semibold mb-3 text-center">Drag any chunk's point; each becomes one code</p>

    <svg viewBox={`0 0 ${W} ${H}`} class="w-full max-w-md mx-auto block" role="img" aria-label="three chunks each encoded to the nearest codebook index">
        <g data-panels></g>
        <circle data-pt="0" r="8" fill="#C96F5A" stroke="#fff" stroke-width="2.5" class="mt-grab" />
        <circle data-pt="1" r="8" fill="#C96F5A" stroke="#fff" stroke-width="2.5" class="mt-grab" />
        <circle data-pt="2" r="8" fill="#C96F5A" stroke="#fff" stroke-width="2.5" class="mt-grab" />
    </svg>

    <p class="text-center font-mono text-sm mt-1">
        codes [ <span data-codes class="text-mt-accent font-semibold">2, 0, 3</span> ]
        &nbsp;&middot;&nbsp; <span class="text-mt-lav">3 bytes</span> for the whole vector
    </p>
</div>

<script>
    import { gsap, draggable } from '../../lib/interact';

    document.querySelectorAll<HTMLElement>('.mt-encode-demo').forEach((root) => {
        const svg = root.querySelector<SVGSVGElement>('svg')!;
        const panelsG = root.querySelector<SVGGElement>('[data-panels]')!;
        const pts = Array.from(root.querySelectorAll<SVGCircleElement>('[data-pt]'));
        const codesEl = root.querySelector<HTMLElement>('[data-codes]')!;

        const pw = 96, top = 26, bot = 120, gap = 20;
        const px0 = (p: number) => gap + p * (pw + (360 - 2 * gap - 3 * pw) / 2);
        const colors = ['#E9A294', '#A2ABDE', '#7E7FBC', '#5E80C9'];
        // each panel: 4 codebook centroids in local 0..100 coords
        const books = [
            [[24, 30], [70, 26], [30, 74], [74, 70]],
            [[28, 24], [68, 36], [40, 72], [78, 64]],
            [[22, 34], [64, 22], [34, 70], [76, 76]],
        ];
        const pos = [[60, 64], [34, 40], [70, 72]]; // current chunk points (local)

        const sx = (p: number, x: number) => px0(p) + (x / 100) * pw;
        const sy = (y: number) => top + (y / 100) * (bot - top);
        const lx = (p: number, svgx: number) => ((svgx - px0(p)) / pw) * 100;
        const ly = (svgy: number) => ((svgy - top) / (bot - top)) * 100;

        const nearest = (p: number) => {
            let bi = 0, bd = Infinity;
            books[p].forEach((c, i) => { const d = (pos[p][0] - c[0]) ** 2 + (pos[p][1] - c[1]) ** 2; if (d < bd) { bd = d; bi = i; } });
            return bi;
        };

        function render() {
            let html = '';
            for (let p = 0; p < 3; p++) {
                const k = nearest(p);
                html += `<rect x="${(px0(p) - 6).toFixed(1)}" y="${(top - 8).toFixed(1)}" width="${pw + 12}" height="${bot - top + 30}" rx="8" fill="#FAF8F5" stroke="#E8E4DF" />`;
                books[p].forEach((c, i) => {
                    const on = i === k;
                    html += `<circle cx="${sx(p, c[0]).toFixed(1)}" cy="${sy(c[1]).toFixed(1)}" r="${on ? 10 : 7}" fill="${colors[i]}" ${on ? 'stroke="#322E45" stroke-width="2"' : ''} />`;
                    html += `<text x="${sx(p, c[0]).toFixed(1)}" y="${(sy(c[1]) + 3).toFixed(1)}" text-anchor="middle" font-size="8" font-family="monospace" fill="#fff">${i}</text>`;
                });
                html += `<text x="${(px0(p) + pw / 2).toFixed(1)}" y="${(bot + 22).toFixed(1)}" text-anchor="middle" font-size="11" font-family="monospace" fill="#C96F5A">#${k}</text>`;
            }
            panelsG.innerHTML = html;
            pts.forEach((el, p) => gsap.set(el, { attr: { cx: sx(p, pos[p][0]), cy: sy(pos[p][1]) } }));
            codesEl.textContent = [0, 1, 2].map((p) => nearest(p)).join(', ');
        }

        pts.forEach((el, p) => draggable(svg, el, (svgx, svgy) => {
            pos[p] = [Math.max(4, Math.min(96, lx(p, svgx))), Math.max(4, Math.min(96, ly(svgy)))];
            render();
        }));
        render();
    });
</script>
